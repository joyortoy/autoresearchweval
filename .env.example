# Core
AUTORESEARCH_LOG_DIR=./logs
AUTORESEARCH_RESULTS_TSV=./results.tsv
AUTORESEARCH_BEST_CONFIG_JSON=./best_config.json

# Optional integrations (disabled by default)
AUTORESEARCH_ENABLE_OPTIONAL_EVALS=0
AUTORESEARCH_INTENT_EVAL=0
AUTORESEARCH_RETRIEVAL_EVAL=0
OPTIONAL_MEMORY_ADAPTER_DIR=/opt/optional_memory_adapter
OPTIONAL_EXTERNAL_EVAL_DIR=/opt/optional_external_eval
OPENCLAW_OPTIONAL_MEMORY_ADAPTER_URL=http://optional-memory-adapter.example:8090
OPTIONAL_EVAL_SOURCE_DIR=/opt/optional_eval_source
AUTORESEARCH_RETRIEVAL_CORPUS=/data/intent-memory

# Optional notifications
AUTORESEARCH_DISCORD_WEBHOOK_URL=
AUTORESEARCH_DISCORD_USERNAME=autoresearch
AUTORESEARCH_DISCORD_AVATAR_URL=
